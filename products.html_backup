      </div>
      <!-- ?card end  -->
      <div class="parallax-section">

        <div class="container py-4">
          <h2 class="section-heading mb-4">CUSTOMER EXPERIENCE</h2>

          <div class="row g-4">

            <!-- Review 1 -->
            <div class="col-md-4">
              <div class="glass-card p-4 text-center text-light h-100">
                <h5 class="mb-2">Akhil P</h5>
                <div class="star mb-3">★★★★★</div>
                <p>
                  Royal Feast exceeded my expectations. The burger was juicy,
                  fries were crispy, and the ambience felt premium.
                </p>
              </div>
            </div>

