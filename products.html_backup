<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome to Royal Feast - Delicious Food Online!</title>
  <style>
    /* Theme tokens */
    :root {
      --nav-height: 80px;
      --rf-bg-main: #020309;
      --rf-bg-gradient: radial-gradient(circle at top, #18181f 0, #020309 55%);
      --rf-text-main: #f7f3e8;
      --rf-muted: #b3ac9c;
      --rf-premium: #d4af37;
      --rf-premium-dark: #b08b27;
      --rf-premium-soft: rgba(212, 175, 55, 0.18);
      --rf-glass-bg: rgba(255, 255, 255, 0.05);
      --rf-glass-border: rgba(212, 175, 55, 0.45);
    }

    html,
    body {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    body {
      padding-top: var(--nav-height);
      min-height: 100vh;
      background:
        linear-gradient(135deg, rgba(0, 0, 0, 0.9), rgba(10, 10, 10, 1)),
        var(--rf-bg-gradient);
      color: var(--rf-text-main);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    /* Soft fade at bottom while scrolling */
    body::after {
      content: "";
      position: fixed;
      left: 0;
      right: 0;
      height: 80px;
      pointer-events: none;
      z-index: 1020;
    }

    body::after {
      bottom: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.95), transparent);
    }

    /* Glass Navbar */


    .carousel,
    #hero,
    .slider-section {
      margin-top: 80px;
    }

    /* Parallax About Section */
    .parallax-about {
      position: relative;
      background: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.9)),
        url("./assets/images/parallex.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      height: 100vh;
      display: flex;
      align-items: center;
      color: #fff;
      padding: 0 15px;
    }

    .parallax-about .row {
      align-items: center;
    }

    .parallax-about .glass-img-wrapper {
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(16px);
      border-radius: 24px;
      border: 1px solid var(--rf-glass-border);
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.75);
      padding: 10px;
      transition: 0.4s ease;
    }

    .parallax-about .glass-img-wrapper:hover {
      transform: scale(1.03);
      box-shadow: 0 0 55px rgba(212, 175, 55, 0.6);
    }

    .parallax-footer {
      position: relative;
      width: 100vw;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      background: linear-gradient(rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.98)),
        url("./assets/images/parallex.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    /* Parallax section starting from testimonials */
    .parallax-section {
      position: relative;
      background: linear-gradient(rgba(0, 0, 0, .9), rgba(0, 0, 0, .98)),
        url("./assets/images/parallex.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      padding: 40px 0;
    }

    /* Glass cards / surfaces */
    .glass-card,
    .card,
    .modal-content {
      background: var(--rf-glass-bg) !important;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--rf-glass-border) !important;
      border-radius: 18px;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.7);
      color: var(--rf-text-main);
      will-change: transform, box-shadow, backdrop-filter;
      transition:
        transform 0.35s ease,
        box-shadow 0.35s ease,
        border-color 0.35s ease,
        background 0.35s ease,
        backdrop-filter 0.35s ease;
    }

    .glass-card:hover,
    .card:hover {
      transform: translateY(-6px) scale(1.02);
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.95);
      border-color: rgba(212, 175, 55, 0.8) !important;
      background: rgba(255, 255, 255, 0.09) !important;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .star {
      color: var(--rf-premium);
      font-size: 1.2rem;
      letter-spacing: 2px;
    }

    /* Shared section heading */
    .section-heading {
      margin-bottom: 1.5rem;
      color: var(--rf-premium);
      font-weight: 600;
      letter-spacing: .18em;
      text-transform: uppercase;
    }

    /* Premium buttons – unify all button colors */
    .btn,
    .btn:focus {
      border-radius: 999px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
    }

    /* Extra glow for navbar button */
    .navbar .btn {
      box-shadow:
        0 0 12px rgba(212, 175, 55, 0.45),
        0 0 28px rgba(212, 175, 55, 0.35);
      transition:
        box-shadow 0.3s ease,
        transform 0.3s ease;
    }

    .navbar .btn:hover {
      box-shadow:
        0 0 18px rgba(212, 175, 55, 0.7),
        0 0 40px rgba(212, 175, 55, 0.6);
      transform: translateY(-1px);
    }

    .btn-warning,
    .btn-success,
    .btn-outline-warning,
    .btn-primary {
      background: linear-gradient(135deg, var(--rf-premium), var(--rf-premium-dark));
      border-color: var(--rf-premium-dark);
      color: #0b0b0b !important;
    }

    .btn-warning:hover,
    .btn-success:hover,
    .btn-outline-warning:hover,
    .btn-primary:hover {
      background: linear-gradient(135deg, var(--rf-premium-dark), var(--rf-premium));
      border-color: var(--rf-premium-dark);
      color: #000 !important;
      transform: translateY(-1px);
    }

    .btn-outline-warning {
      background: transparent;
      color: var(--rf-premium) !important;
      border-color: var(--rf-premium-soft);
    }

    .btn-outline-warning:hover {
      background: var(--rf-premium-soft);
    }

    /* Hero banner – premium layout */
    #carouselExampleAutoplaying {
      height: 100vh;
    }

    #carouselExampleAutoplaying .carousel-inner,
    #carouselExampleAutoplaying .carousel-item {
      height: 100%;
    }

    #carouselExampleAutoplaying .carousel-item {
      position: relative;
    }

    #carouselExampleAutoplaying img {
      height: 100%;
      width: 100%;
      object-fit: cover;
      filter: saturate(1.05) contrast(1.05);
    }

    /* Dark + gold gradient overlay */
    #carouselExampleAutoplaying .carousel-item::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at top, rgba(212, 175, 55, 0.18), transparent 55%),
        linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.95));
    }

    /* Centered glass content block */
    #carouselExampleAutoplaying .carousel-caption {
      bottom: auto;
      top: 52%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: left;
      max-width: 640px;
      width: 100%;
      padding: 24px 32px;
      background: rgba(0, 0, 0, 0.55);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-radius: 24px;
      border: 1px solid var(--rf-glass-border);
      box-shadow: 0 26px 70px rgba(0, 0, 0, 0.85);
    }

    #carouselExampleAutoplaying .carousel-caption h1 {
      font-size: clamp(2.2rem, 4vw, 3rem);
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    #carouselExampleAutoplaying .carousel-caption p {
      color: var(--rf-muted);
      font-size: 1.05rem;
      margin-bottom: 0.75rem;
    }

    /* Optional CTA row inside caption */
    #carouselExampleAutoplaying .carousel-caption .btn {
      margin-top: 0.75rem;
    }

    /* Controls – subtle, premium */
    #carouselExampleAutoplaying .carousel-control-prev-icon,
    #carouselExampleAutoplaying .carousel-control-next-icon {
      filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.8));
    }

    #carouselExampleAutoplaying .carousel-control-prev,
    #carouselExampleAutoplaying .carousel-control-next {
      width: 7%;
    }

    /* Footer */
    .footer-clean {
      padding: 40px 0 20px;
    }

    .footer-title {
      font-weight: 600;
      letter-spacing: .5px;
      margin-bottom: 6px;
    }

    .divider {
      width: 55px;
      height: 2px;
      background: var(--rf-premium);
      margin-bottom: 12px;
    }

    .footer-clean p {
      margin-bottom: 6px;
      font-size: .95rem;
      color: var(--rf-muted);
    }

    .social a {
      width: 36px;
      height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    /* Navbar logo – oval shape */
    .navbar-brand img {
      border-radius: 999px;
      object-fit: cover;
      border: 2px solid var(--rf-premium-soft);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.7);
    }
  </style>
  <link rel="icon" href="./assets/images/favicon.jpg" type="image/jpg">
  <a href="https://api.whatsapp.com/send?phone=918590568859&text=Hello%20Royal%20Feast"
    class="btn btn-success position-fixed bottom-0 end-0 m-4 rounded-circle shadow d-flex align-items-center justify-content-center"
    style="width:65px;height:65px;z-index:1050;" target="_blank">

    <i class="bi bi-whatsapp text-white fs-3"></i>

  </a>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="assets/css/style.css?v=3" rel="stylesheet">
</head>

<body id="home">
  <!-- start navbar -->
  <div class="navbar-wrapper">
    <nav class="navbar navbar-expand-lg glass-navbar">
      <div class="container">
        <!-- Logo -->
        <a class="navbar-brand me-3" href="index.html">
          <img src="./assets/images/foodoglogo.jpg" alt="Logo" width="45" height="45" class="rounded-circle">
        </a>

        <!-- Toggler for mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <!-- Left-aligned Links -->
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link active" href="index.html">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="index.html#about">About Us</a></li>
            <li class="nav-item"><a class="nav-link" href="products.html">Products</a></li>
            <li class="nav-item"><a class="nav-link" href="index.html#offers">Offers</a></li>
            <li class="nav-item"><a class="nav-link" href="index.html#contact">Contact Us</a></li>
          </ul>

          <!-- Right-aligned Button -->
          <div class="d-flex">
            <button class="btn btn-get-started" data-bs-toggle="modal" data-bs-target="#authModal">
              Get Started
            </button>
          </div>
        </div>
      </div>
    </nav>
  </div>
  <!-- Unified Authentication Modal (Redesigned) -->
  <div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content auth-modal-content overflow-hidden">
        <div class="row g-0">
          <!-- Visual Panel -->
          <div class="col-lg-6 d-none d-lg-block modal-split-visual"
            style="background-image: url('./assets/images/royal_feast_login_bg.png');">
            <div class="visual-overlay d-flex flex-column justify-content-end p-5">
              <h2 class="display-5 fw-bold text-white mb-3 head-royal">A Taste of Royalty</h2>
              <p class="text-white-50 lead mb-0">Experience the finest gourmet delights, prepared with passion and
                served with elegance.</p>
            </div>
          </div>

          <!-- Form Panel -->
          <div class="col-lg-6 modal-split-form p-4 p-md-5 bg-dark">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <img src="./assets/images/foodoglogo.jpg" alt="Logo" class="rounded-circle shadow" width="60">
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                aria-label="Close"></button>
            </div>

            <!-- Login View -->
            <div id="loginView">
              <h3 class="head-royal text-warning mb-2">Welcome Back</h3>
              <p class="text-secondary mb-4">Please enter your details to sign in.</p>

              <form>
                <div class="mb-3">
                  <label class="form-label small text-uppercase fw-bold text-secondary">Email Address</label>
                  <input type="email" class="form-control premium-input" placeholder="name@example.com">
                </div>
                <div class="mb-4">
                  <div class="d-flex justify-content-between">
                    <label class="form-label small text-uppercase fw-bold text-secondary">Password</label>
                    <a href="#" class="small text-warning text-decoration-none">Forgot?</a>
                  </div>
                  <input type="password" class="form-control premium-input" placeholder="••••••••">
                </div>
                <button type="submit" class="btn btn-warning w-100 py-3 fw-bold rounded-pill shadow-sm">Sign In</button>
              </form>

              <div class="mt-5 text-center">
                <p class="text-secondary small">Don't have an account?
                  <a href="javascript:void(0)" onclick="toggleAuthView('signup')"
                    class="text-warning fw-bold text-decoration-none ms-1">Create an Account</a>
                </p>
              </div>
            </div>

            <!-- Signup View (Hidden by default) -->
            <div id="signupView" style="display: none;">
              <h3 class="head-royal text-warning mb-2">Join the Feast</h3>
              <p class="text-secondary mb-4">Experience royalty in every bite.</p>

              <form>
                <div class="mb-3">
                  <label class="form-label small text-uppercase fw-bold text-secondary">Full Name</label>
                  <input type="text" class="form-control premium-input" placeholder="John Doe">
                </div>
                <div class="mb-3">
                  <label class="form-label small text-uppercase fw-bold text-secondary">Email Address</label>
                  <input type="email" class="form-control premium-input" placeholder="name@example.com">
                </div>
                <div class="mb-4">
                  <label class="form-label small text-uppercase fw-bold text-secondary">Password</label>
                  <input type="password" class="form-control premium-input" placeholder="••••••••">
                </div>
                <button type="submit" class="btn btn-warning w-100 py-3 fw-bold rounded-pill shadow-sm">Sign Up</button>
              </form>

              <div class="mt-5 text-center">
                <p class="text-secondary small">Already have an account?
                  <a href="javascript:void(0)" onclick="toggleAuthView('login')"
                    class="text-warning fw-bold text-decoration-none ms-1">Sign In</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleAuthView(view) {
      const loginView = document.getElementById('loginView');
      const signupView = document.getElementById('signupView');
      if (view === 'signup') {
        loginView.style.display = 'none';
        signupView.style.display = 'block';
      } else {
        loginView.style.display = 'block';
        signupView.style.display = 'none';
      }
    }
  </script>
